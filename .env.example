# Career Agent — environment variables
# Copy to .env.local and fill in. All secrets are server-side only.

# --- Supabase (SHARES snip's project — use snip's URL/keys. Dashboard stays separate) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key for server-side admin ops (guest-data cleanup job, Storage admin).
SUPABASE_SERVICE_ROLE_KEY=

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=
# One server-side model for all AI calls in v1. Not user-facing.
# Default claude-sonnet-4-6; set to claude-haiku-4-5 for cheap testing.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Adzuna (free developer tier: https://developer.adzuna.com) ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Default country for job search (Adzuna-covered: us, ca, gb, ...). Indonesia not covered.
ADZUNA_DEFAULT_COUNTRY=us

# --- Resend (landing-page "Request access" notifications: https://resend.com) ---
# API key for emailing the operator when someone requests access. If unset, the
# request is still saved; only the notification email is skipped.
RESEND_API_KEY=
# Optional: where access-request notifications are sent (defaults to the operator's email).
ACCESS_REQUEST_NOTIFY_EMAIL=
# Optional: verified sender. Defaults to "Career Agent <onboarding@resend.dev>"
# (Resend's shared sender only delivers to your own Resend account email).
RESEND_FROM=

# --- Site ---
# Used for OAuth redirect URLs. Set to the Vercel URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
